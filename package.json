{
  "name": "@vinkas/base",
  "version": "1.0.0",
  "description": "",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest dev",
    "prepare": "husky"
  },
  "keywords": [
    "vinkas-base"
  ],
  "author": {
    "name": "Vinkas",
    "email": "contact@vinkas.com",
    "url": "https://vinkas.com"
  },
  "contributors": [
    {
      "name": "Vinoth Kannan",
      "email": "vinoth.kannan@vinkas.com",
      "url": "https://vinothkannan.com"
    }
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "bugs": {
    "url": "https://github.com/vinkashq/base-node/issues"
  },
  "homepage": "https://github.com/vinkashq/base-node#readme",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,json,md}": "prettier --write"
  },
  "packageManager": "pnpm@10.33.0"
